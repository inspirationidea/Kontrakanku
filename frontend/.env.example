# ============================================================
# KontrakanKu Frontend — Environment Variables Template
# Salin sesuai kebutuhan:
#   .env.local        → development lokal
#   .env.android      → build Android (ganti IP dengan IP WiFi kamu)
#   .env.production   → build production (ganti dengan domain server)
# ============================================================

# URL Backend API
VITE_API_URL=http://localhost:4000/api

# URL Backend Base (untuk foto/file upload)
VITE_BACKEND_URL=http://localhost:4000
