# ============================================================
# KontrakanKu Backend — Environment Variables
# Salin ke .env dan isi nilainya
# ============================================================

PORT=4000
NODE_ENV=production

# Database (Railway otomatis set ini saat add PostgreSQL)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DB_NAME?schema=public"

# JWT Secret (buat string acak 32+ karakter)
JWT_SECRET="ganti-dengan-secret-panjang-acak-minimal-32-karakter"

# Frontend URL (untuk CORS)
FRONTEND_URL="https://kontrakanku.vercel.app"

# MinIO / S3 Storage (opsional - bisa pakai Cloudinary)
MINIO_ENDPOINT="localhost"
MINIO_PORT=9000
MINIO_ACCESS_KEY="your-access-key"
MINIO_SECRET_KEY="your-secret-key"
MINIO_USE_SSL=false
MINIO_BUCKET_NAME="kontrakanku-assets"

# Webhook Secret (untuk payment gateway)
WEBHOOK_SECRET="ganti-dengan-webhook-secret-yang-kuat"
