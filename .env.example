# ============================================================
# KontrakanKu — Production Environment Variables
# cp .env.example .env  lalu isi semua nilai
# JANGAN commit .env ke git!
# ============================================================

# ── Node Environment ──────────────────────────────────────
NODE_ENV=production

# ── Database PostgreSQL ───────────────────────────────────
DB_USER=kontrakanku_user
DB_PASSWORD=ganti-dengan-password-kuat
DB_NAME=kontrakanku_db

# ── JWT Secret (generate: openssl rand -base64 32) ────────
JWT_SECRET=ganti-dengan-secret-panjang-acak-minimal-32-karakter

# ── Frontend URL (untuk CORS) ─────────────────────────────
# Ganti dengan domain kamu setelah Dokploy setup
FRONTEND_URL=https://kontrakanku.domain-kamu.com

# ── Vite API URLs (untuk build frontend) ─────────────────
# Ganti dengan URL backend setelah deploy
VITE_API_URL=https://api.kontrakanku.domain-kamu.com/api
VITE_BACKEND_URL=https://api.kontrakanku.domain-kamu.com

# ── MinIO Storage ─────────────────────────────────────────
MINIO_ACCESS_KEY=ganti-dengan-minio-access-key
MINIO_SECRET_KEY=ganti-dengan-minio-secret-key-panjang
MINIO_BUCKET_NAME=kontrakanku-assets

# ── Webhook Secret ────────────────────────────────────────
WEBHOOK_SECRET=ganti-dengan-webhook-secret-kuat

# ── Port Mapping (opsional, default sudah ada) ────────────
# BACKEND_PORT=4000
# FRONTEND_PORT=80
# MINIO_PORT=9000
# MINIO_CONSOLE_PORT=9001
